<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reliability Engineering Program Tracker</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <header class="app-header">
    <div>
      <p class="eyebrow">Reliability Engineering Repository</p>
      <h1>Reliability Program Tracker</h1>
      <p class="subhead">Equipment hierarchy, work orders, failures, trends, summaries, and cooperative reviews.</p>
    </div>
    <div class="header-actions">
      <button id="seedDemoBtn" class="secondary">Load Demo Data</button>
      <button id="exportBtn" class="secondary">Export JSON</button>
      <label class="file-btn">Import JSON<input id="importInput" type="file" accept="application/json" /></label>
      <button id="clearBtn" class="danger">Clear Data</button>
    </div>
  </header>

  <main>
    <section class="kpi-grid" id="kpiGrid"></section>

    <nav class="tabs" aria-label="Reliability program sections">
      <button class="tab active" data-tab="dashboard">Dashboard</button>
      <button class="tab" data-tab="equipment">Equipment</button>
      <button class="tab" data-tab="workorders">Work Orders</button>
      <button class="tab" data-tab="failures">Failures</button>
      <button class="tab" data-tab="analysis">Analysis</button>
      <button class="tab" data-tab="reviews">Cooperative Review</button>
    </nav>

    <section id="dashboard" class="panel active-panel">
      <div class="panel-header">
        <div>
          <h2>Reliability Trends</h2>
          <p>Choose a trend view to calculate from your current records.</p>
        </div>
        <div class="button-row">
          <button data-trend="pareto">Failure Pareto</button>
          <button data-trend="downtime">Downtime by Asset</button>
          <button data-trend="type">Failure Type Mix</button>
          <button data-trend="mtbf">MTBF Estimate</button>
          <button data-trend="review">Review Backlog</button>
        </div>
      </div>
      <div id="trendOutput" class="trend-output"></div>
    </section>

    <section id="equipment" class="panel">
      <div class="panel-header"><h2>Equipment Functional Hierarchy</h2></div>
      <form id="equipmentForm" class="form-grid">
        <input name="tag" placeholder="Equipment Tag / ID" required />
        <input name="site" placeholder="Site" />
        <input name="area" placeholder="Area" />
        <input name="system" placeholder="System" />
        <input name="asset" placeholder="Asset" />
        <input name="component" placeholder="Component" />
        <select name="criticality">
          <option>Low</option><option selected>Medium</option><option>High</option><option>Critical</option>
        </select>
        <input name="owner" placeholder="Owner / Department" />
        <button type="submit">Add Equipment</button>
      </form>
      <div id="equipmentTable"></div>
    </section>

    <section id="workorders" class="panel">
      <div class="panel-header"><h2>Work Orders</h2></div>
      <form id="woForm" class="form-grid">
        <input name="woNumber" placeholder="WO Number" required />
        <select name="equipmentTag" id="woEquipmentSelect"></select>
        <select name="woType"><option>Corrective</option><option>Preventive</option><option>Predictive</option><option>Inspection</option><option>Improvement</option></select>
        <select name="priority"><option>Low</option><option>Medium</option><option>High</option><option>Emergency</option></select>
        <input name="dateOpened" type="date" />
        <input name="dateClosed" type="date" />
        <input name="laborHours" type="number" step="0.1" placeholder="Labor Hours" />
        <textarea name="description" placeholder="WO description / notes"></textarea>
        <button type="submit">Add WO</button>
      </form>
      <div id="woTable"></div>
    </section>

    <section id="failures" class="panel">
      <div class="panel-header"><h2>Failure Event Log</h2></div>
      <form id="failureForm" class="form-grid">
        <select name="equipmentTag" id="failureEquipmentSelect"></select>
        <input name="eventDate" type="date" required />
        <select name="failureType"><option>Mechanical</option><option>Electrical</option><option>Controls</option><option>Process</option><option>Human Error</option><option>Unknown</option></select>
        <input name="failureMode" placeholder="Failure Mode ex: bearing failure" />
        <input name="mechanism" placeholder="Mechanism ex: lubrication starvation" />
        <input name="downtimeHours" type="number" step="0.1" placeholder="Downtime Hours" />
        <select name="consequence"><option>Minor</option><option>Production Loss</option><option>Quality Impact</option><option>Safety Risk</option><option>Environmental Risk</option></select>
        <textarea name="correctiveAction" placeholder="Corrective action / containment"></textarea>
        <button type="submit">Log Failure</button>
      </form>
      <div id="failureTable"></div>
    </section>

    <section id="analysis" class="panel">
      <div class="panel-header">
        <div><h2>Generated Analysis Summaries</h2><p>Creates a reliability meeting summary from current data.</p></div>
        <button id="generateSummaryBtn">Generate Summary</button>
      </div>
      <textarea id="summaryOutput" class="summary-box" placeholder="Generated reliability analysis will appear here."></textarea>
    </section>

    <section id="reviews" class="panel">
      <div class="panel-header"><h2>Cooperative Review Workflow</h2></div>
      <form id="reviewForm" class="form-grid">
        <input name="title" placeholder="Review Topic / Action" required />
        <select name="sourceType"><option>Failure Event</option><option>Work Order</option><option>PM Optimization</option><option>Capital Request</option><option>RCA</option></select>
        <select name="level"><option>Draft</option><option>Supervisor Review</option><option>Maintenance Review</option><option>Reliability Engineer Review</option><option>Operations Review</option><option>Reliability Review Board</option><option>Closed / Implemented</option></select>
        <input name="owner" placeholder="Owner" />
        <input name="dueDate" type="date" />
        <textarea name="notes" placeholder="Decision notes / required cooperation"></textarea>
        <button type="submit">Add Review Item</button>
      </form>
      <div id="reviewTable"></div>
    </section>
  </main>

  <template id="tableTemplate"><table><thead></thead><tbody></tbody></table></template>
  <script src="app.js"></script>
</body>
</html>
